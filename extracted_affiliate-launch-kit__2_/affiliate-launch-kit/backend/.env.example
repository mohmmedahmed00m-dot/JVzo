# =============================================================================
# Affiliate Launch Kit — Environment Configuration
# Mirrors Section 9 of the Technical Blueprint exactly.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- Database ---
# PostgreSQL connection string
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Authentication (JWT) ---
# Signs/verifies Access Tokens (256-bit random string)
JWT_SECRET=replace-with-random-256-bit-string
# Signs/verifies Refresh Tokens (separate from JWT_SECRET)
JWT_REFRESH_SECRET=replace-with-another-random-256-bit-string

# --- AI Generation ---
# AI Engine's LLM provider key (all 5 generators)
ANTHROPIC_API_KEY=sk-ant-...

# --- JVZoo Licensing ---
# Verifies authenticity of incoming IPN payloads
JVZOO_SECRET_KEY=string-from-jvzoo-vendor-dashboard

# --- Object Storage (S3-compatible) ---
S3_BUCKET_NAME=affiliate-launch-kit-exports
S3_ACCESS_KEY_ID=provider-issued-access-key
S3_SECRET_ACCESS_KEY=provider-issued-secret-key
S3_REGION=us-east-1

# --- Email (transactional) ---
# Transactional email service (license delivery, password reset)
EMAIL_PROVIDER_API_KEY=provider-issued-email-key

# --- Queue / Background Jobs ---
# BullMQ queue connection for async generation/export jobs
REDIS_URL=redis://host:6379

# --- App ---
# CORS allowlist + links used in transactional emails
FRONTEND_BASE_URL=https://app.example.com
# Runtime environment
NODE_ENV=development
# Backend listen port
PORT=3000
