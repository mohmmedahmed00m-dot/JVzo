# =============================================================================
# LOCAL DEVELOPMENT ENV — FAKE VALUES ONLY (no real keys).
# This file lets the project RUN end-to-end WITHOUT real Anthropic/JVZoo/S3/Email
# credentials. The AI Engine auto-falls-back to a deterministic local mock
# generator when ANTHROPIC_API_KEY is absent/placeholder (see ai-engine service).
# Replace values with real credentials before production use.
# =============================================================================

# --- Database ---
DATABASE_URL=postgres://alk_user:alk_pass@localhost:5432/affiliate_launch_kit

# --- Authentication (JWT) ---
JWT_SECRET=dev-jwt-secret-please-rotate-0123456789abcdef0123456789abcdef
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-please-rotate-0123456789abcdef0123456789

# --- AI Generation (FAKE — triggers local mock generator) ---
ANTHROPIC_API_KEY=sk-ant-fake-placeholder-key-for-local-dev-only

# --- JVZoo Licensing (FAKE — known secret used by IPN test) ---
JVZOO_SECRET_KEY=jvzoo-dev-secret-12345

# --- Object Storage (FAKE — local filesystem storage adapter is used) ---
S3_BUCKET_NAME=affiliate-launch-kit-exports-dev
S3_ACCESS_KEY_ID=fake-local-access-key
S3_SECRET_ACCESS_KEY=fake-local-secret-key
S3_REGION=us-east-1

# --- Email (FAKE — notifications module logs to console instead of sending) ---
EMAIL_PROVIDER_API_KEY=fake-email-provider-key

# --- Queue ---
REDIS_URL=redis://localhost:6379

# --- App ---
FRONTEND_BASE_URL=http://localhost:5173
NODE_ENV=development
PORT=3000
